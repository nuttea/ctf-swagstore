# AWS Bedrock Configuration Template
# このファイルをコピーして .env として使用してください

# ============================================
# AWS認証情報（必須）
# ============================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# ============================================
# Bedrock LLMモデル設定
# ============================================
# 推奨: Claude 3 Haiku (コスト効率)
BEDROCK_LLM_MODEL=anthropic.claude-3-haiku-20240307-v1:0

# その他の選択肢:
# BEDROCK_LLM_MODEL=anthropic.claude-3-sonnet-20240229-v1:0  # バランス型
# BEDROCK_LLM_MODEL=anthropic.claude-3-opus-20240229-v1:0    # 高性能

# ============================================
# Bedrock 埋め込みモデル設定（RAG用）
# ============================================
BEDROCK_EMBEDDING_MODEL=amazon.titan-embed-text-v2:0

# ============================================
# チャットボット動作設定
# ============================================
CHATBOT_ENABLED=true
CHATBOT_MAX_TOKENS=1500
CHATBOT_TEMPERATURE=0.7
CHATBOT_TIMEOUT_SECONDS=30

# ============================================
# RAG（検索拡張生成）設定
# ============================================
RAG_ENABLED=true
RAG_TOP_K=5                    # 検索する類似商品の数
RAG_SIMILARITY_THRESHOLD=0.7   # 類似度の閾値（0-1）

# ============================================
# データベース設定
# ============================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=swagstoredb






