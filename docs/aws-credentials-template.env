# AWS Bedrock Configuration Template
# Copy this file to .env and fill in your credentials

# ============================================
# AWS Credentials (required)
# ============================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# ============================================
# Bedrock LLM Model Configuration
# ============================================
# Recommended: Claude 3 Haiku (cost-efficient)
BEDROCK_LLM_MODEL=anthropic.claude-3-haiku-20240307-v1:0

# Other options:
# BEDROCK_LLM_MODEL=anthropic.claude-3-sonnet-20240229-v1:0  # Balanced
# BEDROCK_LLM_MODEL=anthropic.claude-3-opus-20240229-v1:0    # Highest capability

# ============================================
# Bedrock Embedding Model Configuration (for RAG)
# ============================================
BEDROCK_EMBEDDING_MODEL=amazon.titan-embed-text-v2:0

# ============================================
# Chatbot Behaviour Configuration
# ============================================
CHATBOT_ENABLED=true
CHATBOT_MAX_TOKENS=1500
CHATBOT_TEMPERATURE=0.7
CHATBOT_TIMEOUT_SECONDS=30

# ============================================
# RAG (Retrieval-Augmented Generation) Configuration
# ============================================
RAG_ENABLED=true
RAG_TOP_K=5                    # Number of similar products to retrieve
RAG_SIMILARITY_THRESHOLD=0.7   # Minimum similarity threshold (0-1)

# ============================================
# Database Configuration
# ============================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=swagstoredb
